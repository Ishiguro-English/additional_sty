\def\lphrases{\@ifnextchar<{\@lphrases}{\@lphrases<lr>}}
\def\@lphrases<#1>{\@ifnextchar[{\@@lphrases<#1>}{\@@lphrases<#1>[l]}}
\def\@@lphrases<#1>[#2]{\@ifnextchar({\@@@lphrases<#1>[#2]}{\@@@lphrases<#1>[#2](t)}}
\def\@@@lphrases<#1>[#2](#3){\@ifnextchar|{\@@@@lphrases<#1>[#2](#3)}{\@@@lphrases<#1>[#2](#3)|0pt|}}
\def\@@@@lphrases<#1>[#2](#3)|#4|#5{%
  \savebox{\@tempboxd}{%
    \支柱*[5pt]{%
      \ensuremath{%
        \ifthenelse{\equal{#1}{lr}\OR\equal{#1}{l}}{\left|}{\left.}%
        \kern-.5ex%
        \setbox8\hbox{\begin{tabular}{#2}#5\end{tabular}}%
        \setlength{\@tempdimw}{\dp8+#4}%
        \setbox9 \vtop to \@tempdimw {\leftskip0pt\rightskip0pt\hsize\wd8\noindent\smash{\usebox8}}%
        \usebox9%
        \kern-.5ex%
        \ifthenelse{\equal{#1}{lr}\OR\equal{#1}{r}}{\right|\ }{\right.}%
      }%
    }%
  }%
  \if#3t%
      \setlength{\@tempdimd}{-\ht\@tempboxd + \baselineskip}%
  \else
    \if#3b%
      \setlength{\@tempdimd}{\ht\@tempboxd - \baselineskip + 1pt}%
    \else
      \setlength{\@tempdimd}{0pt}%
    \fi
  \fi
  \raisebox{\@tempdimd}{\usebox{\@tempboxd}}%
}

