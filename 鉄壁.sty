        \ifthenelse{\equal{#1}{S}}{\raisebox{.13zw}{\hinshi{小}}\,}{%
        \ifthenelse{\equal{#1}{Z}}{\raisebox{.13zw}{\hinshi{随}}\,}{%
        \ifthenelse{\equal{#1}{H}}{\raisebox{.13zw}{\hinshi{他}}\,}{%
        \ifthenelse{\equal{#1}{敎}}{\raisebox{.13zw}{\hinshi{教}}\,}{%
        \ifthenelse{\equal{#1}{社}}{\raisebox{.13zw}{\hinshi{社}}\,}{%
