\newcommand{\表現}[1]{\gt{\pl{\bf{\見出しぶら下げ{◆\,}{\bgroup\@表現#1
\@empty\relax\egroup}}}}
}% 改行の具合などは絶対いじらない
\def\@表現#1 #2%
  {%
    \@tfor\@@@表現:=#1\do{\@@表現{\@@@表現}}%
    \ifx#2\@empty\else\@表現@空白\expandafter\@表現\fi#2%
  }%
\newcommand{\@表現@空白}{ }%
\newcommand{\@@表現}[1]%
  {%
    \ifthenelse{\equal{#1}{「}}%
      {\mc{「}\color{red!70!white}}%
      {%
        \ifthenelse{\equal{#1}{」}}%
          {\color{black}\mc{」}}%
          {%
            \ifthenelse{\equal{#1}{，}}%
              {\mc{\color{black}\scalebox{.91}{，\hspace{-2pt}}}}%
              {%
                \ifthenelse{\equal{#1}{S}}%
                  {\raisebox{.13zw}{\textcolor{black}{\hinshi{小}}}\,}%
                  {%
                    \ifthenelse{\equal{#1}{R}}%
                      {\raisebox{.13zw}{\textcolor{black}{\hinshi{論}}}\,}%
                      {%
                        \ifthenelse{\equal{#1}{E}}%
                          {\raisebox{.13zw}{\textcolor{black}{\hinshi{説}}}\,}%
                          {%
                            \ifthenelse{\equal{#1}{Z}}%
                              {\raisebox{.13zw}{\textcolor{black}{\hinshi{随}}}\,}%
                              {\ifthenelse{\equal{#1}{：}}{}{#1}}%
                          }%
                      }%
                  }%
              }%
          }%
      }%
  }%
