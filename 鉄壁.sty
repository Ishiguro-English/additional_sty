      {\mc{\color{black}\scalebox{.91}{#1}}}%
      {%
        \ifthenelse{\equal{#1}{N}}{\raisebox{.13zw}{\hinshi{名}}\,}{%
        \ifthenelse{\equal{#1}{A}}{\raisebox{.13zw}{\hinshi{形}}\,}{%
        \ifthenelse{\equal{#1}{M}}{\raisebox{.13zw}{\hinshi{副}}\,}{%
