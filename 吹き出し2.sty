%\definecolor{bubblegreen}{RGB}{103,184,104}
%\definecolor{bubblegray}{RGB}{241,240,240}

\tcbset{
  commonoptions/.style={
    enhanced,
    enhanced jigsaw,
    %fonttitle=\bfseries,
    %boxed title style={opacityback=0, opacityframe=0},
    sharp corners,
    arc=4mm,
    opacityframe=0,
    after skip=0mm,
    fontupper=\mgfamily,
    before upper=\begin{flushleft},
    after upper=\end{flushleft}
    },
  }

\newtcolorbox{ミーちゃん最初}[1][]{
    commonoptions,
    %attach boxed title to top right={yshift=-7mm, xshift=-2mm},
    top=2mm,%6mm,
    right skip=1.5cm,
    finish={\node[anchor=center, yshift=-7mm,xshift=7mm] at (frame.north east) {\roundperson{ミーちゃん}};},
    %title={#3:},
    rounded corners=north,
    rounded corners=southwest,
    colback=bubblegreen,
    colupper=white,
    before skip=1mm,
    #1}

\newtcolorbox{ミーちゃん最後}[1][]{
    commonoptions,
    right skip=1.5cm,
    rounded corners=northwest,
    rounded corners=south,
    colback=bubblegreen,
    colupper=white,
    before skip=0mm,
    after skip=1mm,
    #1}

\NewEnviron{ミーちゃん単体}{\vspace{1mm}%
\tcbox[commonoptions,
    finish={\node[anchor=center, yshift=-5.5mm,xshift=7mm] at (frame.north east) {\roundperson{ミーちゃん}};},
    rounded corners,
    colback=bubblegreen,
    colupper=white,
    before=\hfill,
    after skip=1mm,
    right skip=1.5cm,
    varwidth upper]
    {\raggedright\BODY}
}

