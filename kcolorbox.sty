\DeclareTColorBox{kcolorbox1}{ o m O{\basiccolor} O{} }{%
enhanced, breakable, right=.8mm, left=1zw, top=2mm, bottom=2mm, colback=white, colbacktitle=#3!50!white, coltext=black, coltitle=white, attach boxed title to top left, sharp corners, fonttitle=\gtfamily, frame hidden, colframe=#3!50!white, 
