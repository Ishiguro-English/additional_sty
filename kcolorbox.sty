\DeclareTColorBox{kcolorbox2}{ o m O{\basiccolor} O{} }{%
enhanced, breakable, right=12pt, left=4pt, top=4pt, bottom=4pt, frame hidden, attach boxed title to top left, colback=white, colbacktitle=white, coltitle=#3!30!\basiccolor,  fonttitle=\gtfamily, 
boxed title style={left=2pt, right=2pt, top=3pt, bottom=0pt, frame hidden},  
underlay unbroken={
    \filldraw[draw=white!75!\basiccolor, fill=white!75!\basiccolor]
    ([xshift=2.5pt]frame.south west) --+(0pt, -2.5pt) 
    --([xshift=-5.5pt, yshift=-2.5pt]frame.south east)
    arc[start angle=-90, end angle=0, x radius=8pt, y radius=3pt]
    --([xshift=2.5pt, yshift=\tcboxedtitleheight-.5pt]frame.north east)
    arc[start angle=0, end angle=90, x radius=2.5pt, y radius=1.5pt] 
    --([yshift=2pt]frame.south east)
    arc[start angle=0, end angle=-90, x radius=8pt, y radius=2pt] --cycle;
    \draw[line width=.5pt, color=\basiccolor]
    ([xshift=-8pt, yshift=\tcboxedtitleheight]frame.north east) 
    --(title.north west) --(frame.south west) 
    --([xshift=-8pt]frame.south east) 
    arc[start angle=-90, end angle=90, x radius=8pt, y radius=2pt] 
    --([xshift=-8pt, yshift=\tcboxedtitleheight+4pt]frame.north east)
    arc[start angle=90, end angle=0, x radius=8pt, y radius=2pt]
    --([yshift=2pt]frame.north east)
    --([yshift=2pt]frame.south east);
    \shade[left color=white, middle color=white, right color=#3!20!white!50!\basiccolor]
    ([yshift=2pt]frame.south east)
    arc[start angle=0, end angle=90, x radius=8pt, y radius=2pt] 
    --([xshift=-8pt, yshift=\tcboxedtitleheight+4pt]frame.north east)
    arc[start angle=90, end angle=0, x radius=8pt, y radius=2pt]
    --([yshift=2pt]frame.north east) --cycle;
    \draw[line width=.5pt, color=\basiccolor]
    ([xshift=-8pt, yshift=4pt+\tcboxedtitleheight]frame.north east) 
    --([xshift=-8pt, yshift=4pt]frame.south east);},
IfValueTF={#1}{title=【#2】〈#1〉}{title=#2},before upper={\段落下げ},#4}


