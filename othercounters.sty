%%%% TikZ を用いて101以上の角数字の出力にも対応した命令 \kakuSuji（引数が101以上でTikZによる出力に切り替え）
\newcommand*\kakuSuji[1]{%
  \setcounter{@tempcounterc}{#1}%
  \ifnum\c@@tempcounterc<101\relax
    \ajKaku{\number\c@@tempcounterc}%
  \else
    \@tempdimc=1zw\relax
    \@zenkakuSpace\nobreak\hspace{-1zw}%
    \setbox9\hbox to 1zw{\yoko\hfill\tikz[outer sep=0pt, inner sep=0pt, baseline=-.5\@tempdimc]%
      \node[draw,rectangle,line width=.03\@tempdimc,text width=.85\@tempdimc,text height=.85\@tempdimc]{%
          \makebox[.85zw][c]{\raisebox{.15zw}{\resizebox{.7zw}{.55zw}{#1}}}%
        };%
      \hfill}%
    \iftdir
      \makebox[1zw][c]{\usebox9}%
    \else
      \raisebox{-.12zw}{\usebox9}%
    \fi
    \nobreak\hspace{-1zw}\nobreak\@zenkakuSpace
  \fi
}

%%%%% カウンタ出力用 \KakuSuji / \KakuSujip / \KakuSujik / \KakuSujizk
\newcommand*\KakuSuji[1]{\expandafter\@KakuSuji\csname c@#1\endcsname}
\newcommand*\@KakuSuji[1]{\kakuSuji{\number#1}}
\newcommand*\KakuSujip[1]{\KakuSuji{#1}.}
\newcommand*\KakuSujik[1]{\KakuSuji{#1})}
\newcommand*\KakuSujizk[1]{\KakuSuji{#1}）}


