%% アルファベットなら数値に変換し，数値なら数値のままで resultcounter に代入する
\def\alphToNum#1{%
  \setcounter{resultcounter}{0}%
  \ifthenelse{\equal{#1}{A}\OR\equal{#1}{a}}{\setcounter{resultcounter}{1}}{}%
  \ifthenelse{\equal{#1}{B}\OR\equal{#1}{b}}{\setcounter{resultcounter}{2}}{}%
  \ifthenelse{\equal{#1}{C}\OR\equal{#1}{c}}{\setcounter{resultcounter}{3}}{}%
  \ifthenelse{\equal{#1}{D}\OR\equal{#1}{d}}{\setcounter{resultcounter}{4}}{}%
  \ifthenelse{\equal{#1}{E}\OR\equal{#1}{e}}{\setcounter{resultcounter}{5}}{}%
  \ifthenelse{\equal{#1}{F}\OR\equal{#1}{f}}{\setcounter{resultcounter}{6}}{}%
  \ifthenelse{\equal{#1}{G}\OR\equal{#1}{g}}{\setcounter{resultcounter}{7}}{}%
  \ifthenelse{\equal{#1}{H}\OR\equal{#1}{h}}{\setcounter{resultcounter}{8}}{}%
  \ifthenelse{\equal{#1}{I}\OR\equal{#1}{i}}{\setcounter{resultcounter}{9}}{}%
  \ifthenelse{\equal{#1}{J}\OR\equal{#1}{j}}{\setcounter{resultcounter}{10}}{}%
  \ifthenelse{\equal{#1}{K}\OR\equal{#1}{k}}{\setcounter{resultcounter}{11}}{}%
  \ifthenelse{\equal{#1}{L}\OR\equal{#1}{l}}{\setcounter{resultcounter}{12}}{}%
  \ifthenelse{\equal{#1}{M}\OR\equal{#1}{m}}{\setcounter{resultcounter}{13}}{}%
  \ifthenelse{\equal{#1}{N}\OR\equal{#1}{n}}{\setcounter{resultcounter}{14}}{}%
  \ifthenelse{\equal{#1}{O}\OR\equal{#1}{o}}{\setcounter{resultcounter}{15}}{}%
  \ifthenelse{\equal{#1}{P}\OR\equal{#1}{p}}{\setcounter{resultcounter}{16}}{}%
  \ifthenelse{\equal{#1}{Q}\OR\equal{#1}{q}}{\setcounter{resultcounter}{17}}{}%
  \ifthenelse{\equal{#1}{R}\OR\equal{#1}{r}}{\setcounter{resultcounter}{18}}{}%
  \ifthenelse{\equal{#1}{S}\OR\equal{#1}{s}}{\setcounter{resultcounter}{19}}{}%
  \ifthenelse{\equal{#1}{T}\OR\equal{#1}{t}}{\setcounter{resultcounter}{20}}{}%
  \ifthenelse{\equal{#1}{U}\OR\equal{#1}{u}}{\setcounter{resultcounter}{21}}{}%
  \ifthenelse{\equal{#1}{V}\OR\equal{#1}{v}}{\setcounter{resultcounter}{22}}{}%
  \ifthenelse{\equal{#1}{W}\OR\equal{#1}{w}}{\setcounter{resultcounter}{23}}{}%
  \ifthenelse{\equal{#1}{X}\OR\equal{#1}{x}}{\setcounter{resultcounter}{24}}{}%
  \ifthenelse{\equal{#1}{Y}\OR\equal{#1}{y}}{\setcounter{resultcounter}{25}}{}%
  \ifthenelse{\equal{#1}{Z}\OR\equal{#1}{z}}{\setcounter{resultcounter}{26}}{}%
  \ifthenelse{\value{resultcounter}=0}{\setcounter{resultcounter}{#1}}{}%
}

