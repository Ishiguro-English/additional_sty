\usepackage{enumerate}           % 番号付き箇条書き \begin{enumerate}[(1)] 

% enumerate 環境の空白設定
% \番号付き箇条書きの空白設定(#1)<#2>[#3]{#4}{#5}
%   #1：\itemsep （項目間に余分に空ける空白。デフォルト 0pt）
%   #2：\rightmargin （右側の余白。デフォルト 0pt）
%   #3：\labelsep （見出しと１文字目の間の空白。デフォルト 1zw）
%   #4：\leftmargin（ページ左端と２行目の先頭文字の距離）
%   #5：\itemindent （見出しのインデント量）
\newlength{\@last@itemsep}    % 最後に設定した itemsep の引数値
\newlength{\@last@rightmargin}   % 最後に設定した rightmargin の真の設定値
\newlength{\@last@labelsep}    % 最後に設定した labelsep の引数値
\newlength{\@last@leftmargin}    % 最後に設定した leftmargin の引数値
\newlength{\@last@itemindent}    % 最後に設定した itemindent の引数値

\newlength{\my@leftmargin}
\setlength{\my@leftmargin}{0pt}
\newlength{\my@rightmargin}
\setlength{\my@rightmargin}{0pt}

\def\番号付き箇条書きの空白設定{\@ifnextchar({\@番号付き箇条書きの空白設定}{\@番号付き箇条書きの空白設定(0pt)}}
\def\@番号付き箇条書きの空白設定(#1){\@ifnextchar<{\@@番号付き箇条書きの空白設定(#1)}{\@@番号付き箇条書きの空白設定(#1)<0pt>}}
\def\@@番号付き箇条書きの空白設定(#1)<#2>{\@ifnextchar[{\@@@番号付き箇条書きの空白設定(#1)<#2>}{\@@@番号付き箇条書きの空白設定(#1)<#2>[1zw]}}
\def\@@@番号付き箇条書きの空白設定(#1)<#2>[#3]#4#5{%
  \setlength{\labelsep}{#3}%
  \setlength{\@last@itemsep}{#1}% % 最後に設定した itemsep の引数値を保存しておく
  \setlength{\@last@rightmargin}{#2}% % 最後に設定した leftmargin の引数値を保存しておく
  \setlength{\@last@labelsep}{#3}% % 最後に設定した itemindent の引数値を保存しておく
  \setlength{\@last@leftmargin}{#4}% % 最後に設定した leftmargin の引数値を保存しておく
  \setlength{\@last@itemindent}{#5}% % 最後に設定した itemindent の引数値を保存しておく
  \setlength{\my@leftmargin}{#4}%
  \setlength{\my@rightmargin}{#2}%
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%
  \def\@enum@{%
    \list
      {\csname label\@enumctr\endcsname}%
      {\usecounter{\@enumctr}\definitionOfm@kelabel\leftmargin\my@leftmargin\itemindent#5\listparindent1zw\rightmargin\my@rightmargin\topsep0pt\itemsep#1}%
  }%
}

\def\definitionOfm@kelabel{\def\makelabel##1{\hss\llap{##1}}}



