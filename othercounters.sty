%%%% mawarikomi の中の jquotation の中で itemize を使ったときにインデントを反映させるために，
%%%% itemize を enumerate の一種にする
\let\@originalitemize\itemize
\let\end@originalitemize\enditemize

\let\originalitem\item

\newenvironment{originalitemize}{\let\item\originalitem\@originalitemize}{\end@originalitemize}


\def\itemize{\@ifnextchar<{\my@itemize}{\my@itemize<\relax>}}
\def\my@itemize<#1>{\@ifnextchar[{\my@@itemize<#1>}{\my@@itemize<#1>[\textbullet]}}
\def\my@@itemize<#1>[#2]{\vspace{\topsep}\begin{enumerate}<#1>[{#2}]}
\def\enditemize{\end{enumerate}\vspace{\topsep}%\環境後のインデント抑制処理
}



%%%% \endenumerate のタイミングで everypar がリセットされてしまう問題に対処するため，
%%%% enumerate 環境全体をグルーピングしておく
\let\@enumerate@\enumerate
\let\@endenumerate@\endenumerate
\def\enumerate{\bgroup\@enumerate@}
\def\endenumerate{\@endenumerate@\egroup}

%%%%%%%% enumerate 環境の定義を，list 系を使わないように書き換え
%%%%%%%% 元の enumerate は originalenumerate に退避
\let\@originalenumerate\enumerate
\let\end@originalenumerate\endenumerate

\newenvironment{originalenumerate}{\let\item\originalitem\@originalenumerate}{\end@originalenumerate}

\newcounter{enumerateLevel}
\setcounter{enumerateLevel}{0}


\newcounter{enumerateItem}
\setcounter{enumerateItem}{0}

\newcounter{superenumerateItem}
\setcounter{superenumerateItem}{0}

\newcounter{supersuperenumerateItem}
\setcounter{supersuperenumerateItem}{0}

\newcounter{supersupersuperenumerateItem}
\setcounter{supersupersuperenumerateItem}{0}

\newcounter{enumerateの開始番号}
\setcounter{enumerateの開始番号}{1}

\def\item直後のparにnopagebreakを込める{しない}

\def\enumerate{\@ifnextchar({\my@enumerate}{\my@enumerate(\value{enumerateの開始番号})}}
\def\my@enumerate(#1){\@ifnextchar<{\my@@enumerate(#1)}{\my@@enumerate(#1)<\relax>}}
\def\my@@enumerate(#1)<#2>{\@ifnextchar[{\my@@@enumerate(#1)<#2>}{\my@@@enumerate(#1)<#2>[\relax]}}
\def\my@@@enumerate(#1)<#2>[#3]{%
  \localsetcounter{enumerateの開始番号}{#1}%
  \def\enum@temp{#3}%
  \def\enum@relax{\relax}%
  \localstepcounter{enumerateLevel}%
  \ifx\enum@temp\enum@relax % 今回 \begin{enumerate}[ ] の手動指定がない場合には，\番号付け変更 で指定された手動型のラベルを，手動型ラベルの候補として読む（自動型のときには \enum@temp は引き続き \relax になる）
      \ifcase\c@enumerateLevel\or
        \let\enum@temp\@enumerateの手動指定型ラベルi\or
        \let\enum@temp\@enumerateの手動指定型ラベルii\or
        \let\enum@temp\@enumerateの手動指定型ラベルiii\or
        \let\enum@temp\@enumerateの手動指定型ラベルiv\or
      \fi
  \fi
  \def\enum@@@temp{#2}%
  \ifx\enum@@@temp\enum@relax
    \@tempdiml\@last@leftmargin
  \else
    \@tempdiml\enum@@@temp
  \fi
  \begin{jquotation}(\@tempdiml)(\@last@rightmargin)[0pt]%
    \parindent=\@last@itemindent
    \ifcase\c@enumerateLevel\or
      \or
        \localsetcounter{superenumerateItem}{\value{enumerateItem}}%
      \or
        \localsetcounter{supersuperenumerateItem}{\value{superenumerateItem}}%
        \localsetcounter{superenumerateItem}{\value{enumerateItem}}%
      \or
        \localsetcounter{supersupersuperenumerateItem}{\value{supersuperenumerateItem}}%
        \localsetcounter{supersuperenumerateItem}{\value{superenumerateItem}}%
        \localsetcounter{superenumerateItem}{\value{enumerateItem}}%
      \or
    \fi
    \localsetcounter{enumerateItem}{\value{enumerateの開始番号}-1}%
    \ifcase\c@enumerateLevel\or
      \localsetcounter{enumi}{\value{enumerateの開始番号}-1}\or
      \localsetcounter{enumii}{\value{enumerateの開始番号}-1}\or
      \localsetcounter{enumiii}{\value{enumerateの開始番号}-1}\or
      \localsetcounter{enumiv}{\value{enumerateの開始番号}-1}\or
    \fi
    \renewcommand{\item}[1][\relax]{%
      \def\enum@@temp{##1}% %%% \item[ ] の手動型ラベル
      \ifcase\c@enumerateLevel\or
        \localstepcounter{enumi}\or
        \localstepcounter{enumii}\or
        \localstepcounter{enumiii}\or
        \localstepcounter{enumiv}\or
      \fi
      \par
      \ifthenelse{\equal{\item直後のparにnopagebreakを込める}{する}}{%
        \def\par{\nopagebreak\@par@\let\par\@par@}%
      }{}%
      \localrefstepcounter{enumerateItem}%
      \ifthenelse{\value{enumerateItem}>\value{enumerateの開始番号}\AND\NOT\lengthtest{\@last@itemsep=0pt}}{\vspace{\@last@itemsep}}{}%
      \見出しはみ出し{%
        \ifx\enum@@temp\enum@relax  %% \item[ ] の手動指定がない場合 
          \ifx\enum@temp\enum@relax  %% \begin{enumerate}[ ] の手動指定がなく，かつ \番号付け変更 で自動型のラベルが指定されていた場合
            \@nameuse{enumCounter\theenumerateLevel}{enumerateItem}%
          \else %% \begin{enumerate}[ ] の手動指定がある場合，または \番号付け変更 で手動型のラベルが指定されていた場合
            \enum@temp\relax
          \fi
        \else %% \item[ ] の手動指定がある場合 
          \enum@@temp\relax
        \fi
        \hspace{\@last@labelsep-1zw}%
      }%
%      \ifx\enum@@temp\enum@relax\else %% \item[ ] の手動指定があった場合には，カウンタを戻す
%        \localaddtocounter{enumerateItem}{-1}%
%      \fi
      \inhibitglue\ignorespaces
    }%
}
\def\endenumerate{\end{jquotation}%\環境後のインデント抑制処理
}




